"use client";

import { useEffect, useState } from "react";
import { Zap, ChevronDown, ChevronUp, ExternalLink } from "lucide-react";
import { cn } from "@/lib/utils";
import type { AlertsResponse, ConvergenceAlert } from "@/types/alerts";

const SEVERITY_CONFIG = {
  critical: {
    label: "Critical",
    dot: "bg-red-500",
    badge: "text-red-400 bg-red-500/10 border border-red-500/30",
    bar: "bg-red-500",
    card: "border-red-500/30 hover:border-red-500/60",
  },
  elevated: {
    label: "Elevated",
    badge: "text-amber-400 bg-amber-500/10 border border-amber-500/30",
    dot: "bg-amber-400",
    bar: "bg-amber-400",
    card: "border-amber-400/30 hover:border-amber-400/60",
  },
  watch: {
    label: "Watch",
    dot: "bg-blue-400",
    badge: "text-blue-400 bg-blue-500/10 border border-blue-500/30",
    bar: "bg-blue-400",
    card: "border-blue-400/20 hover:border-blue-400/40",
  },
};

const SIGNAL_ICONS: Record<string, string> = {
  statistical:  "📊",
  legislative:  "⚖️",
  incident:     "🚨",
};

const GROUP_LABELS: Record<string, string> = {
  african_descent:  "African descent",
  roma:             "Roma",
  muslims:          "Muslims",
  lgbtiq:           "LGBTIQ",
  women:            "Women",
  disabilities:     "Disabilities",
  migrants:         "Migrants",
  jews:             "Jews",
  general:          "General population",
};

const SECTOR_LABELS: Record<string, string> = {
  employment:         "Employment",
  education:          "Education",
  housing:            "Housing",
  healthcare:         "Healthcare",
  law_enforcement:    "Law enforcement",
  essential_services: "Essential services",
  online:             "Online",
  justice:            "Justice",
};

function ScoreDots({ score }: { score: number }) {
  return (
    <div className="flex items-center gap-1">
      {[1, 2, 3].map((i) => (
        <span
          key={i}
          className={cn(
            "w-2 h-2 rounded-full transition-all",
            i <= score
              ? score === 3 ? "bg-red-500" : score === 2 ? "bg-amber-400" : "bg-blue-400"
              : "bg-white/10"
          )}
        />
      ))}
      <span className="text-[10px] text-white/30 font-mono ml-1">{score}/3</span>
    </div>
  );
}

function AlertCard({
  alert,
  onSelectCountry,
}: {
  alert: ConvergenceAlert;
  onSelectCountry: (code: string) => void;
}) {
  const [expanded, setExpanded] = useState(false);
  const cfg = SEVERITY_CONFIG[alert.severity];

  return (
    <div
      className={cn(
        "bg-surface border rounded-lg overflow-hidden transition-colors cursor-pointer",
        cfg.card
      )}
      onClick={() => setExpanded((v) => !v)}
    >
      <div className={cn("h-0.5 w-full", cfg.bar)} />

      <div className="px-4 py-3 flex items-start justify-between gap-3">
        <div className="flex items-start gap-3 min-w-0">
          <div className="flex flex-col items-center gap-1 flex-shrink-0 pt-0.5">
            <span className="text-xs font-bold text-white/70 font-mono">{alert.country}</span>
            <ScoreDots score={alert.convergence_score} />
          </div>

          <div className="min-w-0">
            <div className="flex items-center gap-2 flex-wrap mb-1">
              <span className={cn("px-1.5 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider", cfg.badge)}>
                {cfg.label}
              </span>
              <span className="text-[10px] px-2 py-0.5 bg-white/5 border border-white/10 rounded text-white/40 font-mono">
                {GROUP_LABELS[alert.group_id] ?? alert.group_id}
              </span>
              <span className="text-[10px] px-2 py-0.5 bg-white/5 border border-white/10 rounded text-white/40 font-mono">
                {SECTOR_LABELS[alert.sector] ?? alert.sector}
              </span>
            </div>

            <div className="flex items-center gap-2">
              {alert.has_statistical && <span className="text-xs">{SIGNAL_ICONS.statistical}</span>}
              {alert.has_legislative && <span className="text-xs">{SIGNAL_ICONS.legislative}</span>}
              {alert.has_incident    && <span className="text-xs">{SIGNAL_ICONS.incident}</span>}
              <span className="text-[10px] text-white/30 font-mono">
                {[
                  alert.has_statistical && "Statistical degradation",
                  alert.has_legislative && "AI Act declaration",
                  alert.has_incident    && "Documented incident",
                ].filter(Boolean).join(" · ")}
              </span>
            </div>
          </div>
        </div>

        <div className="flex items-center gap-2 flex-shrink-0">
          <button
            onClick={(e) => {
              e.stopPropagation();
              onSelectCountry(alert.country);
            }}
            className="text-[10px] text-white/40 hover:text-accent border border-white/10 hover:border-accent/40 rounded px-2 py-1 transition-colors font-mono"
          >
            View →
          </button>
          {expanded
            ? <ChevronUp className="w-3.5 h-3.5 text-white/30" />
            : <ChevronDown className="w-3.5 h-3.5 text-white/30" />
          }
        </div>
      </div>

      {expanded && Array.isArray(alert.signal_details) && alert.signal_details.length > 0 && (
        <div className="border-t border-white/5 px-4 py-3 space-y-2.5">
          {alert.signal_details.map((s, i) => (
            <div key={i} className="flex items-start gap-2.5">
              <span className="text-sm flex-shrink-0 mt-0.5">{SIGNAL_ICONS[s.signal_type]}</span>
              <div className="min-w-0">
                <p className="text-xs text-white/70 font-medium leading-snug">{s.title}</p>
                {s.summary && (
                  <p className="text-[10px] text-white/35 leading-relaxed mt-0.5">{s.summary}</p>
                )}
                <div className="flex items-center gap-2 mt-1 flex-wrap">
                  {s.delta_pp !== null && (
                    <span className={cn(
                      "text-[10px] font-mono font-bold",
                      s.delta_pp > 0 ? "text-red-400" : "text-green-400"
                    )}>
                      {s.delta_pp > 0 ? "+" : ""}{s.delta_pp}pp
                    </span>
                  )}
                  {s.source && (
                    <span className="text-[10px] text-white/25 font-mono">{s.source}</span>
                  )}
                  {s.year && (
                    <span className="text-[10px] text-white/20 font-mono">{s.year}</span>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

interface EarlyWarningPanelProps {
  onSelectCountry: (code: string) => void;
}

export function EarlyWarningPanel({ onSelectCountry }: EarlyWarningPanelProps) {
  const [data, setData] = useState<AlertsResponse | null>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState("");
  const [minScore, setMinScore] = useState(1);

  useEffect(() => {
    async function load() {
      setLoading(true);
      setError("");
      try {
        const res = await fetch(`/api/alerts?min_score=${minScore}`);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const json: AlertsResponse = await res.json();
        setData(json);
      } catch (e: any) {
        setError(e.message ?? "Failed to load alerts");
      } finally {
        setLoading(false);
      }
    }
    load();
  }, [minScore]);

  return (
    <div className="space-y-3">
      <div className="flex items-center justify-between">
        <div className="flex items-center gap-2">
          <Zap className="w-4 h-4 text-red-400" />
          <span className="text-sm font-semibold uppercase tracking-wider text-white/40 font-mono">
            Early Warning System
          </span>
          {data && (
            <div className="flex items-center gap-1.5 ml-2">
              {data.critical > 0 && (
                <span className="px-1.5 py-0.5 rounded text-[10px] font-bold bg-red-500/10 border border-red-500/30 text-red-400">
                  {data.critical} critical
                </span>
              )}
              {data.elevated > 0 && (
                <span className="px-1.5 py-0.5 rounded text-[10px] font-bold bg-amber-500/10 border border-amber-500/30 text-amber-400">
                  {data.elevated} elevated
                </span>
              )}
              {data.watch > 0 && (
                <span className="px-1.5 py-0.5 rounded text-[10px] font-bold bg-blue-500/10 border border-blue-500/30 text-blue-400">
                  {data.watch} watch
                </span>
              )}
            </div>
          )}
        </div>

        <div className="flex items-center gap-1 text-[10px] font-mono text-white/30">
          <span>Show</span>
          {[1, 2, 3].map((s) => (
            <button
              key={s}
              onClick={() => setMinScore(s)}
              className={cn(
                "px-2 py-0.5 rounded border transition-colors",
                minScore === s
                  ? "border-accent/50 text-accent bg-accent/10"
                  : "border-white/10 hover:border-white/20"
              )}
            >
              {s}+
            </button>
          ))}
          <span>signals</span>
        </div>
      </div>

      {loading && (
        <div className="bg-surface border border-white/5 rounded-lg p-6 text-center">
          <p className="text-xs text-white/30 font-mono animate-pulse">Loading convergence alerts…</p>
        </div>
      )}

      {error && (
        <div className="bg-red-500/5 border border-red-500/20 rounded-lg p-4">
          <p className="text-xs text-red-400 font-mono">{error}</p>
        </div>
      )}

      {data && !loading && (
        <div className="space-y-2">
          {data.alerts.length === 0 ? (
            <div className="bg-surface border border-white/5 rounded-lg p-6 text-center">
              <p className="text-xs text-white/30">No convergence alerts at this threshold.</p>
            </div>
          ) : (
            data.alerts.map((alert) => (
              <AlertCard
                key={alert.id}
                alert={alert}
                onSelectCountry={onSelectCountry}
              />
            ))
          )}
        </div>
      )}

      <p className="text-[9px] text-white/20 font-mono">
        Convergence score: 3 signals (statistical · legislative · incident) on same country × group × sector · Auto-computed from Supabase
      </p>
    </div>
  );
}
