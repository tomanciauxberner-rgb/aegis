import {
  pgTable,
  uuid,
  varchar,
  text,
  timestamp,
  integer,
  decimal,
  boolean,
  jsonb,
  pgEnum,
  uniqueIndex,
  index,
} from "drizzle-orm/pg-core";

// ─── Enums ──────────────────────────────────────────────

export const roleEnum = pgEnum("user_role", [
  "owner",
  "admin",
  "analyst",
  "viewer",
]);

export const friaStatusEnum = pgEnum("fria_status", [
  "draft",
  "in_review",
  "published",
  "archived",
]);

export const riskLevelEnum = pgEnum("risk_level", [
  "minimal",
  "low",
  "medium",
  "high",
  "critical",
]);

export const aiRiskCategoryEnum = pgEnum("ai_risk_category", [
  "biometrics",
  "critical_infrastructure",
  "education",
  "employment",
  "essential_services",
  "law_enforcement",
  "migration",
  "justice",
]);

// ─── Reference Data ─────────────────────────────────────

export const countries = pgTable(
  "countries",
  {
    id: uuid("id").primaryKey().defaultRandom(),
    code: varchar("code", { length: 2 }).notNull(),
    code3: varchar("code3", { length: 3 }).notNull(),
    name: varchar("name", { length: 100 }).notNull(),
    nameLocal: varchar("name_local", { length: 100 }),
    region: varchar("region", { length: 50 }).notNull(),
    isEuMember: boolean("is_eu_member").notNull().default(false),
    isCandidate: boolean("is_candidate").notNull().default(false),
    joinedEu: integer("joined_eu"),
    population: integer("population"),
    metadata: jsonb("metadata"),
    createdAt: timestamp("created_at", { withTimezone: true })
      .notNull()
      .defaultNow(),
  },
  (table) => [
    uniqueIndex("countries_code_idx").on(table.code),
    uniqueIndex("countries_code3_idx").on(table.code3),
  ]
);

export const rightsCategories = pgTable("rights_categories", {
  id: uuid("id").primaryKey().defaultRandom(),
  code: varchar("code", { length: 30 }).notNull().unique(),
  name: varchar("name", { length: 200 }).notNull(),
  charterArticle: varchar("charter_article", { length: 20 }),
  description: text("description"),
  parentId: uuid("parent_id").references((): any => rightsCategories.id),
});

export const populations = pgTable("populations", {
  id: uuid("id").primaryKey().defaultRandom(),
  code: varchar("code", { length: 30 }).notNull().unique(),
  name: varchar("name", { length: 100 }).notNull(),
  category: varchar("category", { length: 50 }).notNull(),
  description: text("description"),
});

export const surveys = pgTable("surveys", {
  id: uuid("id").primaryKey().defaultRandom(),
  code: varchar("code", { length: 50 }).notNull().unique(),
  name: varchar("name", { length: 200 }).notNull(),
  description: text("description"),
  year: integer("year").notNull(),
  respondents: integer("respondents"),
  countriesCovered: integer("countries_covered"),
  sourceUrl: text("source_url"),
  methodology: text("methodology"),
  lastIngested: timestamp("last_ingested", { withTimezone: true }),
});

export const indicators = pgTable(
  "indicators",
  {
    id: uuid("id").primaryKey().defaultRandom(),
    code: varchar("code", { length: 80 }).notNull().unique(),
    name: varchar("name", { length: 300 }).notNull(),
    description: text("description"),
    unit: varchar("unit", { length: 30 }).notNull().default("percent"),
    surveyId: uuid("survey_id").references(() => surveys.id),
    rightsCategoryId: uuid("rights_category_id").references(
      () => rightsCategories.id
    ),
    topic: varchar("topic", { length: 100 }),
    subtopic: varchar("subtopic", { length: 100 }),
    methodology: text("methodology"),
    limitations: text("limitations"),
  },
  (table) => [index("indicators_topic_idx").on(table.topic)]
);

export const indicatorValues = pgTable(
  "indicator_values",
  {
    id: uuid("id").primaryKey().defaultRandom(),
    indicatorId: uuid("indicator_id")
      .notNull()
      .references(() => indicators.id),
    countryId: uuid("country_id")
      .notNull()
      .references(() => countries.id),
    populationId: uuid("population_id").references(() => populations.id),
    year: integer("year").notNull(),
    value: decimal("value", { precision: 10, scale: 4 }),
    sampleSize: integer("sample_size"),
    confidenceLevel: decimal("confidence_level", { precision: 5, scale: 2 }),
    metadata: jsonb("metadata"),
  },
  (table) => [
    index("iv_country_indicator_idx").on(table.countryId, table.indicatorId),
    index("iv_indicator_year_idx").on(table.indicatorId, table.year),
    uniqueIndex("iv_unique_idx").on(
      table.indicatorId,
      table.countryId,
      table.populationId,
      table.year
    ),
  ]
);

// ─── Multi-tenant Organizations ─────────────────────────

export const organizations = pgTable("organizations", {
  id: uuid("id").primaryKey().defaultRandom(),
  name: varchar("name", { length: 200 }).notNull(),
  slug: varchar("slug", { length: 100 }).notNull().unique(),
  domain: varchar("domain", { length: 200 }),
  sector: varchar("sector", { length: 100 }),
  countryId: uuid("country_id").references(() => countries.id),
  plan: varchar("plan", { length: 20 }).notNull().default("starter"),
  stripeCustomerId: varchar("stripe_customer_id", { length: 100 }),
  metadata: jsonb("metadata"),
  createdAt: timestamp("created_at", { withTimezone: true })
    .notNull()
    .defaultNow(),
  updatedAt: timestamp("updated_at", { withTimezone: true })
    .notNull()
    .defaultNow(),
});

export const orgMembers = pgTable(
  "org_members",
  {
    id: uuid("id").primaryKey().defaultRandom(),
    orgId: uuid("org_id")
      .notNull()
      .references(() => organizations.id, { onDelete: "cascade" }),
    userId: uuid("user_id").notNull(),
    role: roleEnum("role").notNull().default("viewer"),
    invitedBy: uuid("invited_by"),
    joinedAt: timestamp("joined_at", { withTimezone: true })
      .notNull()
      .defaultNow(),
  },
  (table) => [
    uniqueIndex("org_members_unique_idx").on(table.orgId, table.userId),
    index("org_members_user_idx").on(table.userId),
  ]
);

// ─── AI Systems Inventory ───────────────────────────────

export const aiSystems = pgTable(
  "ai_systems",
  {
    id: uuid("id").primaryKey().defaultRandom(),
    orgId: uuid("org_id")
      .notNull()
      .references(() => organizations.id, { onDelete: "cascade" }),
    name: varchar("name", { length: 200 }).notNull(),
    description: text("description"),
    provider: varchar("provider", { length: 200 }),
    version: varchar("version", { length: 50 }),
    riskCategory: aiRiskCategoryEnum("risk_category"),
    deploymentCountries: jsonb("deployment_countries").$type<string[]>(),
    intendedPurpose: text("intended_purpose"),
    affectedPopulations: jsonb("affected_populations").$type<string[]>(),
    isHighRisk: boolean("is_high_risk").notNull().default(false),
    requiresFria: boolean("requires_fria").notNull().default(false),
    status: varchar("status", { length: 20 }).notNull().default("active"),
    metadata: jsonb("metadata"),
    createdAt: timestamp("created_at", { withTimezone: true })
      .notNull()
      .defaultNow(),
    updatedAt: timestamp("updated_at", { withTimezone: true })
      .notNull()
      .defaultNow(),
  },
  (table) => [index("ai_systems_org_idx").on(table.orgId)]
);

// ─── FRIA Assessments ───────────────────────────────────

export const friaAssessments = pgTable(
  "fria_assessments",
  {
    id: uuid("id").primaryKey().defaultRandom(),
    orgId: uuid("org_id")
      .notNull()
      .references(() => organizations.id, { onDelete: "cascade" }),
    aiSystemId: uuid("ai_system_id")
      .notNull()
      .references(() => aiSystems.id, { onDelete: "cascade" }),
    version: integer("version").notNull().default(1),
    status: friaStatusEnum("status").notNull().default("draft"),
    conductedBy: uuid("conducted_by").notNull(),
    reviewedBy: uuid("reviewed_by"),
    context: jsonb("context").$type<{
      deploymentDescription: string;
      operationalFrequency: string;
      duration: string;
      humanOversightMeasures: string;
    }>(),
    affectedGroups: jsonb("affected_groups").$type<
      {
        populationCode: string;
        estimatedSize: string;
        vulnerabilityLevel: string;
        specificConcerns: string;
      }[]
    >(),
    dpiaReference: varchar("dpia_reference", { length: 200 }),
    dpiaOverlapNotes: text("dpia_overlap_notes"),
    mitigationSummary: text("mitigation_summary"),
    overallRiskLevel: riskLevelEnum("overall_risk_level"),
    conclusion: text("conclusion"),
    exportPath: text("export_path"),
    notifiedAuthority: boolean("notified_authority").notNull().default(false),
    notifiedAt: timestamp("notified_at", { withTimezone: true }),
    publishedAt: timestamp("published_at", { withTimezone: true }),
    createdAt: timestamp("created_at", { withTimezone: true })
      .notNull()
      .defaultNow(),
    updatedAt: timestamp("updated_at", { withTimezone: true })
      .notNull()
      .defaultNow(),
  },
  (table) => [
    index("fria_org_idx").on(table.orgId),
    index("fria_system_idx").on(table.aiSystemId),
    index("fria_status_idx").on(table.status),
  ]
);

export const friaRisks = pgTable(
  "fria_risks",
  {
    id: uuid("id").primaryKey().defaultRandom(),
    friaId: uuid("fria_id")
      .notNull()
      .references(() => friaAssessments.id, { onDelete: "cascade" }),
    rightsCategoryId: uuid("rights_category_id").references(
      () => rightsCategories.id
    ),
    title: varchar("title", { length: 300 }).notNull(),
    description: text("description").notNull(),
    likelihood: riskLevelEnum("likelihood").notNull(),
    severity: riskLevelEnum("severity").notNull(),
    overallRisk: riskLevelEnum("overall_risk").notNull(),
    affectedPopulations: jsonb("affected_populations").$type<string[]>(),
    dataEvidence: jsonb("data_evidence").$type<
      {
        indicatorId: string;
        value: number;
        country: string;
        year: number;
        source: string;
      }[]
    >(),
    sortOrder: integer("sort_order").notNull().default(0),
  },
  (table) => [index("fria_risks_fria_idx").on(table.friaId)]
);

export const friaMitigations = pgTable(
  "fria_mitigations",
  {
    id: uuid("id").primaryKey().defaultRandom(),
    friaId: uuid("fria_id")
      .notNull()
      .references(() => friaAssessments.id, { onDelete: "cascade" }),
    riskId: uuid("risk_id").references(() => friaRisks.id, {
      onDelete: "cascade",
    }),
    title: varchar("title", { length: 300 }).notNull(),
    description: text("description").notNull(),
    responsible: varchar("responsible", { length: 200 }),
    deadline: timestamp("deadline", { withTimezone: true }),
    status: varchar("status", { length: 20 }).notNull().default("planned"),
    effectiveness: riskLevelEnum("effectiveness"),
    sortOrder: integer("sort_order").notNull().default(0),
  },
  (table) => [index("fria_mitigations_fria_idx").on(table.friaId)]
);

// ─── Audit Log (append-only) ────────────────────────────

export const auditLog = pgTable(
  "audit_log",
  {
    id: uuid("id").primaryKey().defaultRandom(),
    orgId: uuid("org_id")
      .notNull()
      .references(() => organizations.id),
    userId: uuid("user_id").notNull(),
    action: varchar("action", { length: 50 }).notNull(),
    entityType: varchar("entity_type", { length: 50 }).notNull(),
    entityId: uuid("entity_id"),
    details: jsonb("details"),
    ipAddress: varchar("ip_address", { length: 45 }),
    userAgent: text("user_agent"),
    createdAt: timestamp("created_at", { withTimezone: true })
      .notNull()
      .defaultNow(),
  },
  (table) => [
    index("audit_org_idx").on(table.orgId),
    index("audit_entity_idx").on(table.entityType, table.entityId),
    index("audit_created_idx").on(table.createdAt),
  ]
);
